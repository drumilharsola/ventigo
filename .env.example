# --- Frontend ----------------------------------------------------------------
# Public URL of the backend - must be reachable from the user's browser
# Use https:// in production (WebSocket will automatically use wss://)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# --- Docker Compose (local dev) ---------------------------------------------
POSTGRES_DB=ventigo
POSTGRES_USER=ventigo
POSTGRES_PASSWORD=dev_password

# --- Backend (copy to backend/.env) ------------------------------------------
APP_SECRET_KEY=change_this_to_a_long_random_string_at_least_32_chars
APP_ENV=production

REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?sslmode=require

# Email (Brevo - 9K emails/month free, https://brevo.com)
BREVO_API_KEY=
EMAIL_FROM=Ventigo <your_email@gmail.com>

# Error tracking (Sentry - https://sentry.io)
SENTRY_DSN=

# Push notifications (OneSignal - https://onesignal.com)
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168

CHAT_SESSION_MINUTES=15
HISTORY_TTL_HOURS=1
OTP_EXPIRE_MINUTES=10

GEO_API_URL=http://ip-api.com/json/

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://yourdomain.com

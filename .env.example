# ─── Frontend ────────────────────────────────────────────────────────────────
# Public URL of the backend - must be reachable from the user's browser
# Use https:// in production (WebSocket will automatically use wss://)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ─── Backend (copy to backend/.env) ──────────────────────────────────────────
APP_SECRET_KEY=change_this_to_a_long_random_string_at_least_32_chars
APP_ENV=production

REDIS_URL=redis://redis:6379/0

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM=Flow <your_email@gmail.com>

JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=2

CHAT_SESSION_MINUTES=15
HISTORY_TTL_HOURS=1
OTP_EXPIRE_MINUTES=10

GEO_API_URL=http://ip-api.com/json/

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://yourdomain.com

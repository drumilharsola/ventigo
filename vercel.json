{
  "buildCommand": "cd unburden_app && flutter/bin/flutter build web --release --dart-define=API_BASE_URL=$API_BASE_URL",
  "outputDirectory": "unburden_app/build/web",
  "installCommand": "git clone --depth 1 --branch stable https://github.com/flutter/flutter.git unburden_app/flutter",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

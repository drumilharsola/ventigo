# ─── Application ────────────────────────────────────────────────────────────
APP_SECRET_KEY=change_this_to_a_long_random_secret_key_32chars_min
APP_ENV=development               # development | production

# ─── Database (Neon Postgres - free forever) ────────────────────────────────
# Sign up at https://neon.tech - 0.5 GB storage, always-on primary branch
# Local dev: postgresql+asyncpg://postgres:postgres@localhost:5432/ventigo
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ventigo

# ─── Redis (Upstash) ───────────────────────────────────────────────────────
# Local dev: redis://localhost:6379/0
# Production (Upstash free tier - https://upstash.com): rediss://default:password@host.upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# ─── Email (Brevo - 9K emails/month free) ───────────────────────────────────
# Sign up at https://brevo.com → SMTP & API → API Keys
# Leave blank in dev - verification link will be printed to the backend console
BREVO_API_KEY=

# From address - must be verified in your Brevo dashboard
SMTP_FROM=Ventigo <dhruharsola@gmail.com>

# ─── Error Tracking (Sentry - 5K errors/month free) ─────────────────────────
# Sign up at https://sentry.io → Create project (Python / FastAPI) → copy DSN
SENTRY_DSN=

# ─── Push Notifications (OneSignal - unlimited free) ─────────────────────────
# Sign up at https://app.onesignal.com → App Settings → Keys & IDs
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168

# ─── Session ────────────────────────────────────────────────────────────────
CHAT_SESSION_MINUTES=15
HISTORY_TTL_HOURS=1
OTP_EXPIRE_MINUTES=10

# ─── Public URLs ────────────────────────────────────────────────────────────
# APP_BASE_URL = Backend's own public URL (used in email verification links)
# FRONTEND_URL = Flutter web app URL (where users get redirected after verify)
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

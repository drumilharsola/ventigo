# ─── Application ────────────────────────────────────────────────────────────
APP_SECRET_KEY=change_this_to_a_long_random_secret_key_32chars_min
APP_ENV=development               # development | production

# ─── Redis ──────────────────────────────────────────────────────────────────
# Local dev: redis://localhost:6379/0
# Production (Upstash free tier - https://upstash.com): rediss://default:password@host.upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# Sign up free at https://resend.com - 3,000 emails/month, 100/day
# Leave blank in dev - verification link will be printed to the backend console
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# From address - use onboarding@resend.dev (free tier) or your verified domain
SMTP_FROM=Unburden <dhruharsola@gmail.com>

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=2

# ─── Session ────────────────────────────────────────────────────────────────
CHAT_SESSION_MINUTES=15
HISTORY_TTL_HOURS=1
OTP_EXPIRE_MINUTES=10

# ─── Public URLs ────────────────────────────────────────────────────────────
# APP_BASE_URL = Backend's own public URL (used in email verification links)
# FRONTEND_URL = Flutter web app URL (where users get redirected after verify)
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
